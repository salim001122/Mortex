rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read, write: if true;
      match /{subcollection=**} {
        allow read, write: if true;
      }
    }
    match /signals/{document=**} {
      allow read, write: if true;
    }
    match /chats/{document=**} {
      allow read, write: if true;
    }
    match /system/{document=**} {
      allow read, write: if true;
    }
  }
}
